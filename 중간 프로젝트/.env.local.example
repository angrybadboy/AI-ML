# ============================================================
# 글결 — 환경변수 (TRD §9.2)
# 이 파일을 .env.local 로 복사한 뒤 실제 값을 채워 넣으세요.
# .env.local 은 절대 커밋하지 않습니다 (.gitignore 처리됨).
# ============================================================

# ----- Supabase (Phase 1) -----
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# ⚠️ Service Role Key 는 RLS 우회 권한을 가진 비밀키.
#    절대 NEXT_PUBLIC_ 접두사를 붙이거나 클라이언트 코드에서 import 하지 말 것.
SUPABASE_SERVICE_ROLE_KEY=

# ----- Anthropic Claude (Phase 2 부터 필요) -----
# console.anthropic.com → Settings → API Keys → Create Key
# 형식: sk-ant-...
ANTHROPIC_API_KEY=

# ----- Toss Payments Sandbox (Phase 4 부터 필요) -----
# NEXT_PUBLIC_TOSS_CLIENT_KEY=
# TOSS_SECRET_KEY=

# ----- App -----
# 로컬 개발 시: http://localhost:3000
# Vercel: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
